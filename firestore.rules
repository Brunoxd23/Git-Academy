rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - xp: number (required, >= 0)
    //   - completedLessons: list (required)
    //   - lastActive: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "bruno22052018@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'xp', 'completedLessons', 'lastActive']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.xp is number && data.xp >= 0 &&
             data.completedLessons is list &&
             (!('achievements' in data) || data.achievements is list) &&
             (!('notifications' in data) || data.notifications is list) &&
             data.lastActive is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Anyone authenticated can read user profiles for the ranking
      allow read: if isAuthenticated();
      
      // Users can only create/update their own profile
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
  }
}
